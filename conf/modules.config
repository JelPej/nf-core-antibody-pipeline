/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Config file for defining DSL2 per module options and publishing paths
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Available keys to override module options:
        ext.args   = Additional arguments appended to command in module.
        ext.args2  = Second set of arguments appended to command in module (multi-tool modules).
        ext.prefix = File name prefix for output files.
----------------------------------------------------------------------------------------
*/

process {

    //
    // Default: publish all outputs (except versions.yml) under a directory named
    // after the process (last token of the fully-qualified process name).
    //
    publishDir = [
        path: { "${params.outdir}/${task.process.tokenize(':')[-1].tokenize('_')[0].toLowerCase()}" },
        mode: params.publish_dir_mode,
        saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
    ]

    //
    // AntiFold CDR redesign
    //
    withName: 'ANTIFOLD_CDR' {
        publishDir = [
            path: { "${params.outdir}/antifold" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }

    //
    // Filter AntiFold candidates by log-odds score
    //
    withName: 'FILTER_ANTIFOLD' {
        publishDir = [
            path: { "${params.outdir}/antifold" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }

    //
    // AntiFold split: split multi-sequence FASTA into per-sequence files
    //
    withName: 'ANTIFOLD_SPLIT' {
        publishDir = [
            path: { "${params.outdir}/antifold" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }

    //
    // BioPhi Sapiens humanization
    //
    withName: 'BIOPHI_SAPIENS' {
        publishDir = [
            path: { "${params.outdir}/biophi" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }

    //
    // Filter BioPhi candidates by Sapiens humanness score
    //
    withName: 'FILTER_BIOPHI' {
        publishDir = [
            path: { "${params.outdir}/biophi" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }

    //
    // ABodyBuilder2 structure prediction
    //
    withName: 'ABODYBUILDER2' {
        publishDir = [
            path: { "${params.outdir}/abodybuilder2" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }

    //
    // Filter ABodyBuilder2 structures by B-factor error and CDR RMSD
    //
    withName: 'FILTER_ABODYBUILDER2' {
        publishDir = [
            path: { "${params.outdir}/abodybuilder2" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }

    //
    // OASis humanness scoring
    //
    withName: 'OASIS' {
        publishDir = [
            path: { "${params.outdir}/oasis" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }

    //
    // Rank candidates by OASis percentile
    //
    withName: 'RANK_OASIS' {
        publishDir = [
            path: { "${params.outdir}/oasis" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }

    //
    // MultiQC report
    //
    withName: 'MULTIQC' {
        ext.args   = { params.multiqc_title ? "--title \"$params.multiqc_title\"" : '' }
        publishDir = [
            path: { "${params.outdir}/multiqc" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }

    withName: 'CUSTOM_DUMPSOFTWAREVERSIONS' {
        publishDir = [
            path: { "${params.outdir}/pipeline_info" },
            mode: params.publish_dir_mode,
            pattern: '*_versions.yml'
        ]
    }

}
