nextflow_process {

    name "Test Process OASIS"
    script "../main.nf"
    process "OASIS"

    tag "modules"
    tag "modules_local"
    tag "oasis"

    config "./nextflow.config"

    // Stub test — runs without a built image or the real OASis database
    test("stub - humanized fasta") {

        options "-stub"

        when {
            process {
                """
                input[0] = [
                    [ id: 'Ab001', sample: 'Ab001', chain_heavy: 'H', chain_light: 'L' ],
                    file("${projectDir}/tests/fixtures/test_humanized.fa", checkIfExists: true)
                ]
                input[1] = file("${projectDir}/tests/fixtures/test_humanized.fa")
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert snapshot(
                    process.out.scores.collect { meta, f -> file(f).getName() } +
                    process.out.versions
                ).match("oasis_stub") }
            )
        }
    }

    // Integration test — requires the real OASis database and a built container image
    // Run with: nf-test test --tag requires_oasis_db
    test("integration - humanized fasta [requires_oasis_db]") {

        tag "requires_oasis_db"

        when {
            process {
                """
                input[0] = [
                    [ id: 'Ab001', sample: 'Ab001', chain_heavy: 'H', chain_light: 'L' ],
                    file("${projectDir}/tests/fixtures/test_humanized.fa", checkIfExists: true)
                ]
                input[1] = file(params.oasis_db, checkIfExists: true)
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert process.out.scores.size() == 1 },
                { assert file(process.out.scores[0][1]).exists() },
                { assert snapshot(process.out.versions).match("oasis_versions") }
            )
        }
    }
}
